rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profile Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return (data.get('uid', request.auth.uid) == request.auth.uid)
          && (data.get('email', request.auth.token.email) is string)
          && (data.get('assistantMode', 'Empathetic') in ['Empathetic', 'Professional', 'Brutally Honest', 'Zen'])
          && (data.get('responseTone', 'Balanced') in ['Balanced', 'Formal', 'Casual', 'Humorous'])
          && (data.get('voiceType', 'Soothing') in ['Soothing', 'Energetic', 'Calm', 'Professional'])
          && (data.get('voicePitch', 1.0) is float || data.get('voicePitch', 1.0) is int)
          && (data.get('voiceRate', 1.0) is float || data.get('voiceRate', 1.0) is int)
          && (data.get('isVoiceEnabled', true) is bool)
          && (data.get('instagramHandle', '') is string && data.get('instagramHandle', '').size() <= 100)
          && (data.get('facebookProfile', '') is string && data.get('facebookProfile', '').size() <= 200)
          && (data.get('geminiInfo', '') is string && data.get('geminiInfo', '').size() <= 1000);
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().updatedAt == request.time;

      // --- Message History Rules ---
      match /messages/{messageId} {
        function isValidMessage(data) {
          return data.role in ['user', 'assistant']
            && data.content is string && data.content.size() <= 10000
            && data.timestamp is int;
        }

        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
